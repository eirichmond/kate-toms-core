{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kate-toms-core/kateandtoms-faqs",
  "version": "0.1.0",
  "title": "kate & tom's FAQ Accordion",
  "category": "widgets",
  "icon": "editor-help",
  "description": "A simple FAQ accordion block with question and answer fields.",
  "example": {
    "attributes": {
      "question": "Example Question"
    }
  },
  "supports": {
    "html": true,
    "anchor": true,
    "children": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "kateandtoms-faqs",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "attributes": {
    "question": {
      "type": "string",
      "default": ""
    },
    "isOpen": {
      "type": "boolean",
      "default": false
    }
  }
}