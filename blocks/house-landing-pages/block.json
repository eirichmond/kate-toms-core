{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "kate-toms-core/house-landing-pages",
	"version": "0.1.0",
	"title": "House Landing Pages",
	"category": "widgets",
	"icon": "admin-home",
	"description": "Display house post types ordered by sleeps_max with custom query controls",
	"keywords": ["house", "property", "landing", "sleeps"],
	"example": {},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"postsPerPage": {
			"type": "number",
			"default": -1
		},
		"orderBy": {
			"type": "string",
			"default": "meta_value_num"
		},
		"order": {
			"type": "string",
			"default": "desc"
		},
		"metaKey": {
			"type": "string",
			"default": "sleeps_max"
		},
		"patternStyle": {
			"type": "string",
			"default": "coast"
		},
		"taxonomyFilters": {
			"type": "object",
			"default": {
				"size": [],
				"activity": [],
				"types": [],
				"occasion": [],
				"feature": []
			}
		}
	},
	"textdomain": "kate-toms-core",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
