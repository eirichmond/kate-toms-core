{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "create-block/kateandtoms-image-fader",
	"version": "0.1.0",
	"title": "Kateandtoms Image Fader",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {},
	"supports": {
		"html": false,
		"align": true,
		"dimensions": {
			"aspectRatio": true,
			"minHeight": true
		}
	},
	"attributes": {
		"images": {
			"type": "array",
			"default": [],
			"source": "query",
			"selector": ".slide img",
			"query": {
				"url": {
					"type": "string",
					"source": "attribute",
					"attribute": "src"
				},
				"alt": {
					"type": "string",
					"source": "attribute",
					"attribute": "alt"
				}
			}
		}
	},
	"textdomain": "kateandtoms-image-fader",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
