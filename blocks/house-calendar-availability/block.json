{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "kate-toms-core/house-calendar-availability",
    "version": "1.0.0",
    "title": "House Calendar Availability",
    "category": "widgets",
    "icon": "calendar-alt",
    "description": "Display house availability calendar with booking status and rates.",
    "keywords": ["calendar", "availability", "booking", "rates"],
    "textdomain": "kate-toms-core",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js",
    "render": "file:./render.php",
    "attributes": {
        "houseId": {
            "type": "string",
            "default": ""
        },
        "monthsToShow": {
            "type": "number",
            "default": 6
        },
        "showRates": {
            "type": "boolean",
            "default": true
        },
        "autoRefresh": {
            "type": "boolean",
            "default": false
        },
        "refreshInterval": {
            "type": "number",
            "default": 20
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"]
    }
}
